# ── Job Scheduler — Environment Variables ──
# Copy to .env and adjust as needed.  Values shown are EXAMPLES only.

# Host port the API is exposed on (container always listens on 8000).
APP_PORT=8010

# Async PostgreSQL connection string.
# In Docker Compose the host is "db"; for local dev use "localhost".
DATABASE_URL=postgresql+asyncpg://scheduler:scheduler@db:5432/scheduler

# Scheduler poll interval in milliseconds (how often it checks for due jobs).
SCHEDULER_POLL_INTERVAL_MS=500
